{
  "manifest_version": 3,
  "name": "PR Review Launcher",
  "version": "1.0.0",
  "description": "Adds a PR review launcher to GitHub pull requests for Cursor CLI (agent) or Claude Code",
  "permissions": ["storage"],
  "host_permissions": ["https://github.com/*", "https://github.intuit.com/*"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/pull/*", "https://github.intuit.com/*/pull/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
